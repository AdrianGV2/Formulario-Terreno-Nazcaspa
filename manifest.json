<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Formulario Interno</title>

<!-- ============================================================
     CONFIGURACIÓN — edita solo estas 3 líneas con tus datos
     ============================================================ -->
<script>
  window.APP_CONFIG = {
    FORM_URL: "https://forms.office.com/r/TU-CODIGO-AQUI", // 👉 pega aquí el link de tu Microsoft Form
    COMPANY_NAME: "Tu Empresa",                              // 👉 nombre que aparece en pantalla
    APP_TITLE: "Formulario Interno"                          // 👉 título de la app
  };
</script>
<!-- ============================================================ -->

<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0F2333">
<link rel="icon" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Formulario">
<meta name="mobile-web-app-capable" content="yes">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  :root{
    --bg-deep:      #0F2333;
    --bg-surface:   #16324A;
    --bg-surface-2: #1C3C58;
    --accent:       #2D9C9E;
    --accent-light: #4FC1C4;
    --text-primary: #F5F8FA;
    --text-muted:   #93A9BA;
    --line:         rgba(255,255,255,0.10);
  }

  *{ box-sizing:border-box; }

  html,body{
    height:100%;
    margin:0;
    background:var(--bg-deep);
    color:var(--text-primary);
    font-family:'Inter', system-ui, sans-serif;
    -webkit-font-smoothing:antialiased;
  }

  body{
    min-height:100dvh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    padding:24px;
    position:relative;
    overflow:hidden;
  }

  /* fondo tipo "hoja de formulario": líneas horizontales sutiles */
  body::before{
    content:"";
    position:absolute;
    inset:0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 47px,
      var(--line) 47px,
      var(--line) 48px
    );
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 40%, transparent 85%);
    pointer-events:none;
  }

  .card{
    position:relative;
    width:100%;
    max-width:380px;
    background:var(--bg-surface);
    border:1px solid var(--line);
    border-radius:20px;
    padding:36px 28px 30px;
    text-align:center;
    box-shadow:0 20px 60px rgba(0,0,0,0.35);
  }

  .badge{
    width:64px;
    height:64px;
    margin:0 auto 20px;
    border-radius:16px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:var(--bg-surface-2);
    border:1px solid var(--line);
  }

  .badge svg{ width:30px; height:30px; }

  .eyebrow{
    font-family:'Inter', sans-serif;
    font-size:12px;
    font-weight:600;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--accent-light);
    margin:0 0 6px;
  }

  h1{
    font-family:'Space Grotesk', sans-serif;
    font-size:23px;
    font-weight:700;
    line-height:1.25;
    margin:0 0 10px;
    color:var(--text-primary);
  }

  p.desc{
    font-size:14.5px;
    line-height:1.55;
    color:var(--text-muted);
    margin:0 0 26px;
  }

  .btn{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    width:100%;
    padding:15px 20px;
    border:none;
    border-radius:12px;
    background:var(--accent);
    color:#052426;
    font-family:'Inter', sans-serif;
    font-size:15.5px;
    font-weight:600;
    cursor:pointer;
    transition:transform .15s ease, background .15s ease;
    -webkit-tap-highlight-color:transparent;
  }
  .btn:hover{ background:var(--accent-light); }
  .btn:active{ transform:scale(0.97); }

  .btn svg{ width:18px; height:18px; flex-shrink:0; }

  .lock-note{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:6px;
    margin-top:18px;
    font-size:12.5px;
    color:var(--text-muted);
  }
  .lock-note svg{ width:13px; height:13px; opacity:.8; }

  .footer{
    margin-top:22px;
    font-size:11.5px;
    color:var(--text-muted);
    opacity:.6;
    letter-spacing:.02em;
  }

  .status{
    margin-top:14px;
    font-size:12.5px;
    color:var(--accent-light);
    min-height:16px;
  }

  @media (prefers-reduced-motion: no-preference){
    .card{ animation: rise .5s ease both; }
    @keyframes rise{
      from{ opacity:0; transform:translateY(10px); }
      to{ opacity:1; transform:translateY(0); }
    }
  }
</style>
</head>
<body>

  <div class="card">
    <div class="badge">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="5" y="3" width="14" height="18" rx="2" stroke="#4FC1C4" stroke-width="1.6"/>
        <path d="M8.5 8H15.5" stroke="#4FC1C4" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M8.5 12H15.5" stroke="#4FC1C4" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M8.5 16H12.5" stroke="#4FC1C4" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </div>

    <p class="eyebrow" id="companyLabel">Empresa</p>
    <h1 id="titleLabel">Formulario Interno</h1>
    <p class="desc">
      Este acceso es exclusivo para personal autorizado. Al continuar, iniciarás sesión con tu cuenta corporativa de Microsoft.
    </p>

    <button class="btn" id="openFormBtn">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 6L15 12L9 18" stroke="#052426" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Iniciar sesión y abrir formulario
    </button>

    <div class="lock-note">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="10" width="16" height="10" rx="2" stroke="#93A9BA" stroke-width="1.6"/>
        <path d="M8 10V7a4 4 0 0 1 8 0v3" stroke="#93A9BA" stroke-width="1.6"/>
      </svg>
      <span>Acceso restringido a cuentas de la organización</span>
    </div>

    <div class="status" id="statusMsg"></div>
  </div>

  <p class="footer" id="footerLabel">Formulario Interno</p>

<script>
  const cfg = window.APP_CONFIG;
  document.getElementById('companyLabel').textContent = cfg.COMPANY_NAME;
  document.getElementById('titleLabel').textContent = cfg.APP_TITLE;
  document.getElementById('footerLabel').textContent = cfg.COMPANY_NAME + ' · ' + cfg.APP_TITLE;
  document.title = cfg.APP_TITLE;

  const btn = document.getElementById('openFormBtn');
  const statusMsg = document.getElementById('statusMsg');

  btn.addEventListener('click', () => {
    if (!cfg.FORM_URL || cfg.FORM_URL.includes('TU-CODIGO-AQUI')) {
      statusMsg.textContent = 'Configura FORM_URL en index.html antes de usar la app.';
      return;
    }
    statusMsg.textContent = 'Abriendo formulario…';
    // Navegación de página completa (no iframe): evita bloqueos de Microsoft
    // y permite que el flujo de inicio de sesión funcione con normalidad.
    window.location.href = cfg.FORM_URL;
  });

  // Registro del service worker (permite instalar la app y mostrar
  // esta pantalla incluso sin conexión; el formulario en sí requiere internet).
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('service-worker.js').catch(() => {});
    });
  }
</script>
</body>
</html>
